PORT=8080
DATABASE_DSN=user:password@tcp(127.0.0.1:3306)/openletter?charset=utf8mb4&parseTime=True&loc=Local
JWT_SECRET=change-me-to-a-long-random-string

# Path to a Firebase Admin SDK service account JSON file.
FIREBASE_CREDENTIALS_FILE=./secrets/firebase-service-account.json

# Cloudinary — image hosting for property photos.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
CLOUDINARY_FOLDER=openletter/stays

# hiero CSV export — 비밀 키. 호출 측은 X-API-Key 헤더로 보냄.
HIERO_EXPORT_API_KEY=
